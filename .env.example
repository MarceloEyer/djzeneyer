# ============================================================================
# API ENDPOINTS
# ============================================================================
VITE_WP_REST_URL=https://your-site.com/wp-json/
VITE_WP_SITE_URL=https://your-site.com

# ============================================================================
# SECURITY
# ============================================================================
VITE_TURNSTILE_SITE_KEY=

# ============================================================================
# ROLLBACK / DEPLOYMENT (Used by scripts/rollback.js)
# ============================================================================
SSH_HOST=your-server-ip
SSH_USER=your-username
SSH_PORT=22
REMOTE_ROOT=/var/www/your-site.com
THEME_NAME=zentheme

# ============================================================================
# CLOUDFLARE (Used by scripts/publish-dns-aid-cloudflare.mjs and CI/CD cache purge)
# In GitHub Actions: add as repository secrets CLOUDFLARE_API_TOKEN and CLOUDFLARE_ZONE_ID
# Required permissions: Zone.DNS (Edit), Zone.Cache Purge (Purge)
# ============================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================================================
# GITHUB SECRETS INVENTORY (not needed locally — set in repo Settings > Secrets)
# ============================================================================
# SSH_PRIVATE_KEY         — Hostinger SSH key
# SSH_HOST                — your-server-ip
# SSH_PORT                — 22
# SSH_USER                — your-username
# INDEXNOW_KEY            — IndexNow submission key
# VITE_WC_CONSUMER_KEY    — WooCommerce API key
# VITE_WC_CONSUMER_SECRET — WooCommerce API secret
# VITE_GOOGLE_CLIENT_ID   — Google OAuth client ID
# CLOUDFLARE_API_TOKEN    — Cloudflare API token (DNS Edit + Cache Purge)
# CLOUDFLARE_ZONE_ID      — Cloudflare Zone ID for djzeneyer.com

# ============================================================================
# WEB BOT AUTH - RFC 9421 HTTP Message Signatures
# Public key published at /.well-known/http-message-signatures-directory (JWKS)
# Private key must NEVER be committed - store as GitHub Secret: WEB_BOT_AUTH_PRIVATE_KEY_D
# kid: djzeneyer-bot-v3 (Ed25519)
# ============================================================================
WEB_BOT_AUTH_PRIVATE_KEY_D=
