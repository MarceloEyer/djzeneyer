# ============================================================================
# API ENDPOINTS
# ============================================================================
VITE_WP_REST_URL=https://your-site.com/wp-json/
VITE_WP_SITE_URL=https://your-site.com

# ============================================================================
# SECURITY
# ============================================================================
VITE_TURNSTILE_SITE_KEY=

# ============================================================================
# ROLLBACK / DEPLOYMENT (Used by scripts/rollback.js)
# ============================================================================
SSH_HOST=your-server-ip
SSH_USER=your-username
SSH_PORT=22
REMOTE_ROOT=/var/www/your-site.com
THEME_NAME=djzeneyer

# ============================================================================
# CLOUDFLARE DNS-AID PUBLISHING (Used by scripts/publish-dns-aid-cloudflare.mjs)
# ============================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================================================
# WEB BOT AUTH — RFC 9421 HTTP Message Signatures
# Public key published at /.well-known/http-message-signatures-directory (JWKS)
# Private key must NEVER be committed — store as GitHub Secret: WEB_BOT_AUTH_PRIVATE_KEY_D
# kid: djzeneyer-bot-v2 (Ed25519)
# ============================================================================
WEB_BOT_AUTH_PRIVATE_KEY_D=
