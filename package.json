{
  "name": "dj-zen-eyer-app",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "generate-sitemaps": "node scripts/generate-sitemap.js",
    "prerender": "node scripts/prerender.js",
    "generate-markdown": "node scripts/generate-markdown.mjs",
    "build": "tsc && vite build",
    "build:full": "npm run generate-sitemaps && npm run build && npm run prerender && npm run generate-markdown",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "context:sync": "node scripts/sync-context-versions.mjs",
    "facts:check": "node scripts/check-public-facts.mjs",
    "seo:check": "node scripts/check-seo-invariants.mjs",
    "i18n:check": "node scripts/check-i18n-parity.mjs",
    "utf8:check": "node scripts/check-utf8-content.mjs",
    "workflow-names:check": "node scripts/check-workflow-names.mjs",
    "arch:check": "node scripts/check-architecture-boundaries.mjs",
    "docs:links": "node scripts/check-broken-docs-links.mjs",
    "api:inventory": "node scripts/generate-api-inventory.mjs",
    "api:inventory:check": "node scripts/generate-api-inventory.mjs --check",
    "format": "prettier --write .",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "rollback": "node scripts/rollback.js",
    "indexnow": "node scripts/submit-indexnow.mjs",
    "dns-aid:publish": "node scripts/publish-dns-aid-cloudflare.mjs --skip-doh",
    "dns-aid:dry": "node scripts/publish-dns-aid-cloudflare.mjs --dry-run --skip-doh",
    "dns-aid:verify": "node scripts/check-dns-aid.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.101.2",
    "dompurify": "^3.4.11",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.10.2",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.47.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "yauzl": "3.2.1"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
