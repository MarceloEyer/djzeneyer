{
  "name": "dj-zen-eyer-app",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-sitemaps": "node scripts/generate-sitemap.js",
    "prerender": "node scripts/prerender.js",
    "build": "tsc && vite build",
    "build:full": "npm run generate-sitemaps && npm run build && npm run prerender",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "context:sync": "node scripts/sync-context-versions.mjs",
    "i18n:check": "node scripts/check-i18n-parity.mjs",
    "utf8:check": "node scripts/check-utf8-content.mjs",
    "format": "prettier --write .",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "rollback": "node scripts/rollback.js"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.2",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.100.11",
    "dompurify": "^3.4.5",
    "framer-motion": "^12.39.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^4.2.1",
    "terser": "^5.47.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-compression": "^0.5.1"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "yauzl": "3.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
